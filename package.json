{
  "name": "@feyman/vue-log-viewer",
  "version": "0.1.1",
  "description": "A high-performance Vue 3 log viewer with virtual scrolling and real-time streaming",
  "type": "module",
  "main": "./dist/vue-log-viewer.umd.cjs",
  "module": "./dist/vue-log-viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-log-viewer.js",
      "require": "./dist/vue-log-viewer.umd.cjs"
    },
    "./dist/style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "commitlint": "commitlint --edit",
    "semantic-release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/feyman/vue-log-viewer.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "log",
    "viewer",
    "log-viewer",
    "virtual-scrolling",
    "sse",
    "streaming",
    "real-time"
  ],
  "author": "feyman",
  "license": "MIT",
  "peerDependencies": {
    "pinia": "^2.1.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@vueuse/core": "^10.0.0",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "pinia": "^2.1.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  }
}
